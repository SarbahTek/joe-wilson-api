# ── DATABASE ──────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/mrwilson?schema=public"

# ── JWT ───────────────────────────────────────────────
JWT_SECRET="replace-with-64-char-random-string"
JWT_REFRESH_SECRET="replace-with-different-64-char-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ── SERVER ────────────────────────────────────────────
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# ── STRIPE (fill in when payment provider is chosen) ──
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── AWS S3 / CLOUDFLARE R2 ────────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_REGION="auto"
S3_ENDPOINT=""

# ── MUX VIDEO ─────────────────────────────────────────
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
MUX_SIGNING_KEY_ID=""
MUX_SIGNING_PRIVATE_KEY=""

# ── EMAIL (RESEND) ────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@mrwilson.com"
ADMIN_EMAIL="joseph@mrwilson.com"

# ── REDIS ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
