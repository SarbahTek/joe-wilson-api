# ─────────────────────────────────────────────────────────────────────────────
# .env.example — SAFE TEMPLATE. Copy to .env and fill in real values.
# NEVER commit your real .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Get this from your Neon dashboard → Connection string → Pooled connection
DATABASE_URL="postgresql://user:password@host-pooler.neon.tech/dbname?sslmode=require&channel_binding=require"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-64-char-random-hex-string"
JWT_REFRESH_SECRET="replace-with-different-64-char-random-hex-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"
# Comma-separated list of allowed frontend origins
FRONTEND_URLS="http://localhost:3000"

# ── STRIPE ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── AWS S3 / CLOUDFLARE R2 ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_REGION="auto"
S3_ENDPOINT=""

# ── MUX VIDEO ─────────────────────────────────────────────────────────────────
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
MUX_SIGNING_KEY_ID=""
MUX_SIGNING_PRIVATE_KEY=""

# ── EMAIL (RESEND) ────────────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@yourdomain.com"
ADMIN_EMAIL="you@yourdomain.com"

# ── REDIS (Upstash) ───────────────────────────────────────────────────────────
# IMPORTANT: Must be a rediss:// URL — NOT a "redis-cli --tls -u ..." command
# Get this from Upstash dashboard → Database → REST URL → change to rediss://
REDIS_URL="rediss://default:YOUR_TOKEN@your-host.upstash.io:6379"

# ── SWAGGER DOCS (optional token to protect /docs in production) ──────────────
DOCS_TOKEN=""
